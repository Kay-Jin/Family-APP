# Flask JWT for /auth/wechat-login and all Bearer-protected SQLite APIs (change in production).
JWT_SECRET=change-me-in-production

WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret
# Optional: HMAC secret for derived Supabase passwords (defaults to Flask JWT secret).
# If you deploy Supabase Edge Function wechat-supabase-auth, set the same value there as WECHAT_DERIVE_SECRET.
WECHAT_DERIVE_SECRET=change-me-wechat-derive

# WeChat mobile login → Supabase (see /auth/wechat-supabase). Use service_role only on the server.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: notify linked Supabase users (see PATCH /users/me) via Edge Function send-fcm-push.
PUSH_DISPATCH_SECRET=same_secret_as_in_supabase_edge_function
# Optional; default is {SUPABASE_URL}/functions/v1/send-fcm-push
# SUPABASE_FUNCTIONS_URL=https://YOUR_PROJECT.supabase.co/functions/v1/send-fcm-push

DATABASE_URL=sqlite:///./family_app.db
